OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=gpt-4o-mini
ASSISTANT_NAME=cassandra
ASSISTANT_ALIASES=cassandra,casandra,cassanda
INPUT_MODE=text
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TRANSCRIPTION_LANGUAGE=pt
TRANSCRIPTION_PROMPT=A fala principal e em portugues do Brasil. Preserve nomes proprios e titulos de musicas no idioma original.
MIC_CHUNK_SECONDS=1
MIC_DEBUG=true
WAKE_TIMEOUT_SECONDS=10
ON_SOUND_PATH=assets/on.mp3
OFF_SOUND_PATH=assets/off.mp3
STARTUP_SOUND_PATH=assets/turn-on.mp3
COMMAND_CAPTURE_MAX_SECONDS=12
COMMAND_SILENCE_CHUNKS=3
COMMAND_END_SILENCE_SECONDS=3.0
VOICE_ENABLED=true
VOICE_LANG=pt-br
VOICE_RATE=165

# ── Busca na internet (web-agent): desligado por padrão ────────────────────
WEB_SEARCH_ENABLED=false

# ── Integração com o web-agent ─────────────────────────────────────────────
WEB_AGENT_URL=http://192.168.100.52:8000
WEB_AGENT_EMAIL=cassandra@assistant.local
WEB_AGENT_PASSWORD=CassandraAgent123!
# Tempo máximo (segundos) para aguardar resposta do web-agent
WEB_AGENT_TIMEOUT=90
